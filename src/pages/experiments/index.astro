---
import { getCollection } from "astro:content";
import ArticleCard from "../../components/ArticleCard.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const entries = (await getCollection("experiments", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<BaseLayout title="Experiments | kt5rc" description="検証記事、PoC の一覧">
  <section class="page-intro">
    <SectionHeader
      eyebrow="Experiments"
      title="検証記事とPoC"
      description="導入前の比較、運用判断、構成の見極めを残すためのセクションです。"
    />
    <div class="card-grid">
      {entries.map((entry) => (
        <ArticleCard
          href={`/experiments/${entry.slug}/`}
          title={entry.data.title}
          description={entry.data.description}
          meta={`${entry.data.date.toLocaleDateString("ja-JP")} / ${entry.data.status}`}
          tags={entry.data.tags}
        />
      ))}
    </div>
  </section>
</BaseLayout>
