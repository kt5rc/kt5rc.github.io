---
import { getCollection } from "astro:content";
import ArticleCard from "../components/ArticleCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { TopicTabs } from "../components/TopicTabs";
import BaseLayout from "../layouts/BaseLayout.astro";

const [blog, experiments, notes] = await Promise.all([
  getCollection("blog", ({ data }) => !data.draft),
  getCollection("experiments", ({ data }) => !data.draft),
  getCollection("notes", ({ data }) => !data.draft)
]);

const featured = [
  ...blog.map((entry) => ({ ...entry, collection: "blog" as const })),
  ...experiments.map((entry) => ({ ...entry, collection: "experiments" as const })),
  ...notes.map((entry) => ({ ...entry, collection: "notes" as const }))
]
  .filter((entry) => entry.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const topicData = [
  {
    id: "react",
    label: "React",
    title: "UI設計と副作用制御",
    description: "Hooks設計、React Compiler前提の実装、状態境界の整理を中心に扱います。",
    points: ["useEffectEvent", "startTransition", "Form設計"]
  },
  {
    id: "poc",
    label: "PoC",
    title: "検証記事を先に残す",
    description: "性能比較や運用判断は、結論だけでなく前提条件もMDXで残します。",
    points: ["Astro Islands", "配信導線", "ベンチ比較"]
  },
  {
    id: "library",
    label: "Notes",
    title: "ライブラリ備忘録を短く保つ",
    description: "APIの再確認が多い領域は、後で読み返せる密度を優先します。",
    points: ["Zod", "TanStack Query", "Vitest"]
  }
];

const collectionMeta = {
  blog: "Blog",
  experiments: "Experiment",
  notes: "Note"
} as const;
---

<BaseLayout title="kt5rc | TS / React Notes">
  <section class="hero">
    <div>
      <p class="eyebrow">TypeScript / React focused</p>
      <h1>React技術ブログを、PoCと備忘録まで同じ運用線で回す。</h1>
      <p class="hero-copy">
        記事、検証、ライブラリメモを Astro + MDX に集約し、GitHub Pages へ単一導線で公開する構成です。
      </p>
    </div>
    <TopicTabs client:load topics={topicData} />
  </section>

  <section>
    <SectionHeader
      eyebrow="Featured"
      title="最新の注力テーマ"
      description="記事種別をまたいで、いま整理したい内容を前面に出します。"
    />
    <div class="card-grid">
      {featured.map((entry) => (
        <ArticleCard
          href={`/${entry.collection}/${entry.slug}/`}
          title={entry.data.title}
          description={entry.data.description}
          meta={`${collectionMeta[entry.collection]} / ${entry.data.date.toLocaleDateString("ja-JP")}`}
          tags={entry.data.tags}
        />
      ))}
    </div>
  </section>
</BaseLayout>
