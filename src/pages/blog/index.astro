---
import { getCollection } from "astro:content";
import ArticleCard from "../../components/ArticleCard.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const entries = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<BaseLayout title="Blog | kt5rc" description="React / TypeScript の技術ブログ一覧">
  <section class="page-intro">
    <SectionHeader
      eyebrow="Blog"
      title="React技術ブログ"
      description="状態管理、副作用、設計判断を中心に、実装で詰まりやすい点を整理します。"
    />
    <div class="card-grid">
      {entries.map((entry) => (
        <ArticleCard
          href={`/blog/${entry.slug}/`}
          title={entry.data.title}
          description={entry.data.description}
          meta={entry.data.date.toLocaleDateString("ja-JP")}
          tags={entry.data.tags}
        />
      ))}
    </div>
  </section>
</BaseLayout>
